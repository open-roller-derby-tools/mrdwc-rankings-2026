{
  "name": "mrdwc-rankings-2026",
  "description": "Directus endpoint extension for MRDWC Rankings 2026",
  "icon": "extension",
  "version": "1.0.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-endpoint"
  ],
  "type": "module",
  "directus:extension": {
    "type": "endpoint",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^17.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.1.3",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
